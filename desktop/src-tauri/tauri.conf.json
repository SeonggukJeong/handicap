{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Handicap",
  "version": "0.3.0",
  "identifier": "com.handicap.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      { "label": "main", "title": "Handicap", "url": "splash.html", "width": 1280, "height": 860 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
